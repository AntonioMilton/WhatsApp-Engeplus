# ==== Meta WhatsApp Cloud API ====
# Token do sistema (permanente) gerado no Meta for Developers
WHATSAPP_TOKEN=EAAG...
# ID do número de telefone (Phone Number ID) — NÃO é o número em si
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Token de verificação que VOCÊ inventa e cola também no painel da Meta
WHATSAPP_VERIFY_TOKEN=engeplus-suporte-2026
# App Secret do app da Meta (Configurações do app -> Básico). Vazio = pula validação de assinatura.
META_APP_SECRET=
# WhatsApp Business Account ID (WABA) — opcional, para uso futuro
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ==== IA ====
# Provedor: openai | anthropic
AI_PROVIDER=anthropic

# OpenAI (usado se AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (usado se AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ==== Servidor ====
PORT=3002

# ==== Painel de monitoramento (/admin) ====
ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha

# ==== Jira (criação e acompanhamento automático de chamados) ====
# E-mail da conta Atlassian que o bot usa + API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_EMAIL=antonio.milton@engeplus.eng.br
JIRA_API_TOKEN=coloque-o-token-aqui
JIRA_BASE_URL=https://ti-petkov.atlassian.net
JIRA_PROJECT_KEY=SUP
# accountId do responsável padrão dos chamados (AntonioMilton)
JIRA_ASSIGNEE_ACCOUNT_ID=712020:128a5a09-e336-4fa4-8510-194b1a4c2dd3
# Intervalo (segundos) do monitor que verifica mudanças nos tickets
JIRA_POLL_SECONDS=60
